import { useState } from "react";
import {
  Shield, Search, Eye, Check, X, Clock,
  AlertCircle, CheckCircle, XCircle, Upload,
  User, Phone, MapPin, FileText, Camera,
  BadgeCheck, RefreshCw,
} from "lucide-react";

const KYC_APPLICATIONS = [
  { id: "KYC-2026-0012", buyer: "Ahmad Bilal",   phone: "0300-1234567", city: "Lahore",     cnic: "35201-1234567-1", product: "Samsung Galaxy S24 Ultra", amount: 89999,  submitted: "Mar 13, 2026", status: "pending",  avatar: "AB", color: "#3b82f6", docs: ["cnic_front", "cnic_back", "selfie", "income_proof"] },
  { id: "KYC-2026-0011", buyer: "Hina Butt",     phone: "0321-9876543", city: "Karachi",    cnic: "42101-9876543-2", product: "iPhone 15 Pro Max",        amount: 259999, submitted: "Mar 12, 2026", status: "pending",  avatar: "HB", color: "#8b5cf6", docs: ["cnic_front", "cnic_back", "selfie"] },
  { id: "KYC-2026-0010", buyer: "Murad Khan",    phone: "0333-5556789", city: "Islamabad",  cnic: "61101-5556789-3", product: "MacBook Pro M3",           amount: 349999, submitted: "Mar 10, 2026", status: "approved", avatar: "MK", color: "#10b981", docs: ["cnic_front", "cnic_back", "selfie", "income_proof", "utility_bill"] },
  { id: "KYC-2026-0009", buyer: "Sara Anwar",    phone: "0345-1112222", city: "Faisalabad", cnic: "33100-1112222-4", product: "Sony PlayStation 5",       amount: 79999,  submitted: "Mar 09, 2026", status: "approved", avatar: "SA", color: "#f59e0b", docs: ["cnic_front", "cnic_back", "selfie"] },
  { id: "KYC-2026-0008", buyer: "Faisal Mir",    phone: "0312-3334444", city: "Multan",     cnic: "36302-3334444-5", product: "LG OLED 65\" TV",         amount: 189999, submitted: "Mar 08, 2026", status: "rejected", avatar: "FM", color: "#ef4444", docs: ["cnic_front", "cnic_back"] },
  { id: "KYC-2026-0007", buyer: "Zara Hussain",  phone: "0307-7778888", city: "Rawalpindi", cnic: "37405-7778888-6", product: "iPad Pro M2 12.9\"",       amount: 179999, submitted: "Mar 07, 2026", status: "approved", avatar: "ZH", color: "#06b6d4", docs: ["cnic_front", "cnic_back", "selfie", "income_proof"] },
  { id: "KYC-2026-0006", buyer: "Ali Hassan",    phone: "0315-2223333", city: "Lahore",     cnic: "35202-2223333-7", product: "Google Pixel 8 Pro",       amount: 199999, submitted: "Mar 06, 2026", status: "pending",  avatar: "AH", color: "#d946ef", docs: ["cnic_front", "cnic_back", "selfie"] },
];

const STATUS_CONFIG = {
  pending:  { label: "Pending Review", bg: "#fef3c7", color: "#92400e", border: "#fde68a", icon: Clock         },
  approved: { label: "Approved",       bg: "#d1fae5", color: "#065f46", border: "#a7f3d0", icon: CheckCircle   },
  rejected: { label: "Rejected",       bg: "#fee2e2", color: "#991b1b", border: "#fecaca", icon: XCircle       },
};

const DOC_LABELS: Record<string, string> = {
  cnic_front:   "CNIC Front",
  cnic_back:    "CNIC Back",
  selfie:       "Live Selfie",
  income_proof: "Income Proof",
  utility_bill: "Utility Bill",
};

type KycStatus = keyof typeof STATUS_CONFIG;

const VendorKYCPage = () => {
  const [search, setSearch]       = useState("");
  const [statusFilter, setStatus] = useState("all");
  const [detail, setDetail]       = useState<typeof KYC_APPLICATIONS[0] | null>(null);
  const [apps, setApps]           = useState(KYC_APPLICATIONS);
  const [rejectionNote, setNote]  = useState("");

  const F = { fontFamily: "'DM Sans', system-ui, sans-serif" };

  const filtered = apps.filter((a) => {
    const matchSearch = a.buyer.toLowerCase().includes(search.toLowerCase()) || a.id.includes(search) || a.cnic.includes(search);
    const matchStatus = statusFilter === "all" || a.status === statusFilter;
    return matchSearch && matchStatus;
  });

  const updateStatus = (id: string, newStatus: string) => {
    setApps((prev) => prev.map((a) => a.id === id ? { ...a, status: newStatus } : a));
    if (detail?.id === id) setDetail((prev) => prev ? { ...prev, status: newStatus } : prev);
  };

  const pendingCount  = apps.filter((a) => a.status === "pending").length;
  const approvedCount = apps.filter((a) => a.status === "approved").length;
  const rejectedCount = apps.filter((a) => a.status === "rejected").length;

  const stats = [
    { label: "Total Submitted", val: apps.length,    color: "#2563eb", bg: "#eff6ff",  icon: Shield      },
    { label: "Pending Review",  val: pendingCount,   color: "#f59e0b", bg: "#fffbeb",  icon: Clock       },
    { label: "Approved",        val: approvedCount,  color: "#10b981", bg: "#ecfdf5",  icon: CheckCircle },
    { label: "Rejected",        val: rejectedCount,  color: "#ef4444", bg: "#fee2e2",  icon: XCircle     },
  ];

  return (
    <div style={{ ...F, minHeight: "100%" }}>

      {/* Header */}
      <div style={{ display: "flex", alignItems: "flex-start", justifyContent: "space-between", marginBottom: "24px", flexWrap: "wrap", gap: "12px" }}>
        <div>
          <h1 style={{ fontSize: "22px", fontWeight: 900, color: "#0f172a", margin: "0 0 4px", letterSpacing: "-0.02em" }}>KYC Verification</h1>
          <p style={{ fontSize: "13px", color: "#94a3b8", margin: 0 }}>Review and verify buyer identity documents</p>
        </div>
        {pendingCount > 0 && (
          <div style={{ display: "flex", alignItems: "center", gap: "8px", padding: "8px 14px", borderRadius: "12px", background: "#fef3c7", border: "1px solid #fde68a" }}>
            <AlertCircle size={16} color="#f59e0b" />
            <span style={{ fontSize: "12px", fontWeight: 700, color: "#92400e" }}>{pendingCount} applications need review</span>
          </div>
        )}
      </div>

      {/* Stats */}
      <div style={{ display: "grid", gridTemplateColumns: "repeat(4,1fr)", gap: "14px", marginBottom: "22px" }}>
        {stats.map((s) => (
          <div key={s.label} style={{ background: "white", borderRadius: "16px", border: "1.5px solid rgba(37,99,235,0.07)", padding: "16px 18px", display: "flex", alignItems: "center", gap: "14px", boxShadow: "0 2px 8px rgba(0,0,0,0.04)" }}>
            <div style={{ width: "40px", height: "40px", borderRadius: "11px", background: s.bg, display: "flex", alignItems: "center", justifyContent: "center", flexShrink: 0 }}>
              <s.icon size={18} color={s.color} />
            </div>
            <div>
              <div style={{ fontSize: "22px", fontWeight: 900, color: "#0f172a", lineHeight: 1 }}>{s.val}</div>
              <div style={{ fontSize: "11px", color: "#94a3b8", marginTop: "3px" }}>{s.label}</div>
            </div>
          </div>
        ))}
      </div>

      {/* Filters */}
      <div style={{ background: "white", borderRadius: "16px", border: "1.5px solid rgba(37,99,235,0.07)", padding: "14px 18px", marginBottom: "16px", display: "flex", alignItems: "center", gap: "10px", flexWrap: "wrap", boxShadow: "0 2px 8px rgba(0,0,0,0.03)" }}>
        <div style={{ position: "relative", flex: 1, minWidth: "200px" }}>
          <Search size={14} color="#94a3b8" style={{ position: "absolute", left: "12px", top: "50%", transform: "translateY(-50%)", pointerEvents: "none" }} />
          <input placeholder="Search by name, CNIC, or KYC ID…" value={search} onChange={(e) => setSearch(e.target.value)}
            style={{ width: "100%", height: "38px", paddingLeft: "34px", borderRadius: "10px", border: "1.5px solid #e2e8f0", fontSize: "13px", outline: "none", boxSizing: "border-box", ...F, background: "#f8fafc", color: "#0f172a" }} />
        </div>
        {(["all", "pending", "approved", "rejected"] as const).map((s) => (
          <button key={s} onClick={() => setStatus(s)}
            style={{ height: "36px", paddingInline: "14px", borderRadius: "9px", border: "none", cursor: "pointer", fontSize: "11px", fontWeight: 700, transition: "all 0.18s", ...F, textTransform: "capitalize",
              background: statusFilter === s ? "linear-gradient(135deg,#2563eb,#7c3aed)" : "#f1f5f9",
              color: statusFilter === s ? "white" : "#64748b",
              boxShadow: statusFilter === s ? "0 4px 12px rgba(37,99,235,0.3)" : "none",
            }}>
            {s === "all" ? "All Applications" : s}
          </button>
        ))}
      </div>

      {/* Cards grid */}
      <div style={{ display: "grid", gridTemplateColumns: "repeat(auto-fill,minmax(320px,1fr))", gap: "16px" }}>
        {filtered.map((app) => {
          const sc = STATUS_CONFIG[app.status as KycStatus];
          return (
            <div key={app.id} style={{ background: "white", borderRadius: "20px", border: "1.5px solid rgba(37,99,235,0.07)", overflow: "hidden", boxShadow: "0 2px 12px rgba(0,0,0,0.05)", transition: "transform 0.2s, box-shadow 0.2s" }}
              onMouseEnter={e => { (e.currentTarget as HTMLElement).style.transform = "translateY(-2px)"; (e.currentTarget as HTMLElement).style.boxShadow = "0 10px 30px rgba(0,0,0,0.1)"; }}
              onMouseLeave={e => { (e.currentTarget as HTMLElement).style.transform = "none"; (e.currentTarget as HTMLElement).style.boxShadow = "0 2px 12px rgba(0,0,0,0.05)"; }}>

              {/* Card header */}
              <div style={{ padding: "16px 18px", borderBottom: "1px solid #f1f5f9", display: "flex", alignItems: "center", gap: "12px" }}>
                <div style={{ width: "44px", height: "44px", borderRadius: "13px", background: `linear-gradient(135deg,${app.color},${app.color}bb)`, display: "flex", alignItems: "center", justifyContent: "center", fontSize: "15px", fontWeight: 900, color: "white", flexShrink: 0, boxShadow: `0 4px 12px ${app.color}44` }}>
                  {app.avatar}
                </div>
                <div style={{ flex: 1, minWidth: 0 }}>
                  <p style={{ fontSize: "14px", fontWeight: 800, color: "#0f172a", margin: "0 0 2px" }}>{app.buyer}</p>
                  <p style={{ fontSize: "10px", color: "#94a3b8", margin: 0, fontFamily: "monospace" }}>{app.id}</p>
                </div>
                <span style={{ display: "inline-flex", alignItems: "center", gap: "4px", fontSize: "10px", fontWeight: 700, padding: "4px 10px", borderRadius: "20px", background: sc.bg, color: sc.color, border: `1px solid ${sc.border}`, whiteSpace: "nowrap" }}>
                  <sc.icon size={9} /> {sc.label}
                </span>
              </div>

              {/* Card body */}
              <div style={{ padding: "14px 18px" }}>
                {/* Product */}
                <div style={{ background: "#f8fafc", borderRadius: "10px", padding: "10px 12px", marginBottom: "12px" }}>
                  <p style={{ fontSize: "11px", color: "#94a3b8", margin: "0 0 2px" }}>APPLYING FOR</p>
                  <p style={{ fontSize: "12px", fontWeight: 700, color: "#0f172a", margin: "0 0 2px" }}>{app.product}</p>
                  <p style={{ fontSize: "13px", fontWeight: 900, color: "#2563eb", margin: 0 }}>Rs {app.amount.toLocaleString()}</p>
                </div>

                {/* Info grid */}
                <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: "8px", marginBottom: "12px" }}>
                  {[
                    { icon: Phone,    label: "Phone",     val: app.phone },
                    { icon: MapPin,   label: "City",      val: app.city },
                    { icon: FileText, label: "CNIC",      val: app.cnic },
                    { icon: Clock,    label: "Submitted", val: app.submitted },
                  ].map(({ icon: Icon, label, val }) => (
                    <div key={label} style={{ display: "flex", alignItems: "flex-start", gap: "6px" }}>
                      <Icon size={12} color="#94a3b8" style={{ marginTop: "2px", flexShrink: 0 }} />
                      <div>
                        <p style={{ fontSize: "9px", color: "#94a3b8", margin: "0 0 1px", fontWeight: 600, textTransform: "uppercase", letterSpacing: "0.05em" }}>{label}</p>
                        <p style={{ fontSize: "11px", color: "#374151", fontWeight: 600, margin: 0 }}>{val}</p>
                      </div>
                    </div>
                  ))}
                </div>

                {/* Docs */}
                <div style={{ marginBottom: "14px" }}>
                  <p style={{ fontSize: "10px", fontWeight: 700, color: "#374151", margin: "0 0 8px", textTransform: "uppercase", letterSpacing: "0.06em" }}>Documents Submitted</p>
                  <div style={{ display: "flex", gap: "6px", flexWrap: "wrap" }}>
                    {app.docs.map((doc) => (
                      <span key={doc} style={{ fontSize: "10px", fontWeight: 600, padding: "3px 8px", borderRadius: "6px", background: "#ecfdf5", color: "#065f46", border: "1px solid #a7f3d0", display: "flex", alignItems: "center", gap: "4px" }}>
                        <CheckCircle size={8} /> {DOC_LABELS[doc]}
                      </span>
                    ))}
                    {/* Missing docs */}
                    {Object.keys(DOC_LABELS).filter((d) => !app.docs.includes(d)).map((doc) => (
                      <span key={doc} style={{ fontSize: "10px", fontWeight: 600, padding: "3px 8px", borderRadius: "6px", background: "#fef3c7", color: "#92400e", border: "1px solid #fde68a", display: "flex", alignItems: "center", gap: "4px" }}>
                        <AlertCircle size={8} /> {DOC_LABELS[doc]}
                      </span>
                    ))}
                  </div>
                </div>

                {/* Actions */}
                <div style={{ display: "flex", gap: "8px" }}>
                  <button onClick={() => setDetail(app)}
                    style={{ flex: 1, height: "36px", borderRadius: "10px", background: "#f1f5f9", border: "none", cursor: "pointer", fontSize: "12px", fontWeight: 700, color: "#475569", display: "flex", alignItems: "center", justifyContent: "center", gap: "5px", ...F }}>
                    <Eye size={13} /> Review
                  </button>
                  {app.status === "pending" && (
                    <>
                      <button onClick={() => updateStatus(app.id, "approved")}
                        style={{ flex: 1, height: "36px", borderRadius: "10px", background: "#d1fae5", border: "none", cursor: "pointer", fontSize: "12px", fontWeight: 700, color: "#065f46", display: "flex", alignItems: "center", justifyContent: "center", gap: "5px", ...F }}>
                        <Check size={13} /> Approve
                      </button>
                      <button onClick={() => updateStatus(app.id, "rejected")}
                        style={{ flex: 1, height: "36px", borderRadius: "10px", background: "#fee2e2", border: "none", cursor: "pointer", fontSize: "12px", fontWeight: 700, color: "#991b1b", display: "flex", alignItems: "center", justifyContent: "center", gap: "5px", ...F }}>
                        <X size={13} /> Reject
                      </button>
                    </>
                  )}
                  {app.status !== "pending" && (
                    <button onClick={() => updateStatus(app.id, "pending")}
                      style={{ height: "36px", paddingInline: "12px", borderRadius: "10px", background: "#f1f5f9", border: "none", cursor: "pointer", fontSize: "12px", fontWeight: 700, color: "#475569", display: "flex", alignItems: "center", justifyContent: "center", gap: "5px", ...F }}>
                      <RefreshCw size={12} /> Reset
                    </button>
                  )}
                </div>
              </div>
            </div>
          );
        })}
      </div>

      {/* Detail Panel */}
      {detail && (
        <>
          <div onClick={() => setDetail(null)} style={{ position: "fixed", inset: 0, background: "rgba(0,0,0,0.3)", backdropFilter: "blur(4px)", zIndex: 998 }} />
          <div style={{ position: "fixed", top: 0, right: 0, bottom: 0, width: "min(460px,95vw)", background: "white", zIndex: 999, boxShadow: "-20px 0 60px rgba(0,0,0,0.15)", display: "flex", flexDirection: "column", ...F }}>
            <div style={{ background: "linear-gradient(135deg,#2563eb,#7c3aed)", padding: "20px 24px", display: "flex", alignItems: "center", justifyContent: "space-between" }}>
              <div>
                <p style={{ color: "rgba(255,255,255,0.7)", fontSize: "11px", margin: "0 0 2px", fontFamily: "monospace" }}>{detail.id}</p>
                <h2 style={{ color: "white", fontWeight: 800, fontSize: "16px", margin: 0 }}>KYC Review — {detail.buyer}</h2>
              </div>
              <button onClick={() => setDetail(null)} style={{ width: "32px", height: "32px", borderRadius: "50%", background: "rgba(255,255,255,0.2)", border: "none", color: "white", cursor: "pointer", fontSize: "18px", display: "flex", alignItems: "center", justifyContent: "center" }}>×</button>
            </div>

            <div style={{ flex: 1, overflowY: "auto", padding: "20px" }}>
              {/* Document viewer mockup */}
              <p style={{ fontSize: "11px", fontWeight: 700, color: "#374151", marginBottom: "10px", textTransform: "uppercase", letterSpacing: "0.06em" }}>Document Review</p>
              <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: "10px", marginBottom: "16px" }}>
                {detail.docs.map((doc) => (
                  <div key={doc} style={{ borderRadius: "12px", overflow: "hidden", border: "1.5px solid #e2e8f0", cursor: "pointer" }}
                    onMouseEnter={e => (e.currentTarget.style.borderColor = "#2563eb")}
                    onMouseLeave={e => (e.currentTarget.style.borderColor = "#e2e8f0")}>
                    <div style={{ height: "80px", background: "linear-gradient(135deg,#f1f5f9,#e2e8f0)", display: "flex", alignItems: "center", justifyContent: "center" }}>
                      {doc === "selfie" ? <Camera size={28} color="#94a3b8" /> : <FileText size={28} color="#94a3b8" />}
                    </div>
                    <div style={{ padding: "8px 10px", display: "flex", alignItems: "center", gap: "6px" }}>
                      <CheckCircle size={11} color="#10b981" />
                      <span style={{ fontSize: "11px", fontWeight: 600, color: "#374151" }}>{DOC_LABELS[doc]}</span>
                    </div>
                  </div>
                ))}
              </div>

              {/* Verification checklist */}
              <p style={{ fontSize: "11px", fontWeight: 700, color: "#374151", marginBottom: "10px", textTransform: "uppercase", letterSpacing: "0.06em" }}>Verification Checklist</p>
              <div style={{ display: "flex", flexDirection: "column", gap: "6px", marginBottom: "16px" }}>
                {[
                  "CNIC is valid and not expired",
                  "Photo matches CNIC",
                  "Selfie is clear and recent",
                  "Income proof is sufficient for installment",
                  "No fraud indicators detected",
                ].map((item, i) => (
                  <label key={item} style={{ display: "flex", alignItems: "center", gap: "10px", padding: "10px 12px", borderRadius: "10px", background: "#f8fafc", cursor: "pointer" }}>
                    <input type="checkbox" defaultChecked={i < 3} style={{ width: "15px", height: "15px", accentColor: "#2563eb" }} />
                    <span style={{ fontSize: "12px", color: "#374151", fontWeight: 500 }}>{item}</span>
                  </label>
                ))}
              </div>

              {/* Rejection note */}
              {detail.status === "pending" && (
                <div style={{ marginBottom: "16px" }}>
                  <label style={{ fontSize: "11px", fontWeight: 700, color: "#374151", display: "block", marginBottom: "6px" }}>REJECTION NOTE (if rejecting)</label>
                  <textarea rows={3} value={rejectionNote} onChange={(e) => setNote(e.target.value)}
                    placeholder="Explain why the application is being rejected…"
                    style={{ width: "100%", padding: "10px 12px", borderRadius: "10px", border: "1.5px solid #e2e8f0", fontSize: "12px", outline: "none", resize: "none", boxSizing: "border-box", ...F }} />
                </div>
              )}
            </div>

            {/* Panel footer */}
            {detail.status === "pending" && (
              <div style={{ padding: "16px 20px", borderTop: "1px solid #f1f5f9", display: "flex", gap: "10px" }}>
                <button onClick={() => { updateStatus(detail.id, "rejected"); setDetail(null); }}
                  style={{ flex: 1, height: "42px", borderRadius: "11px", background: "#fee2e2", border: "none", color: "#991b1b", fontSize: "13px", fontWeight: 700, cursor: "pointer", display: "flex", alignItems: "center", justifyContent: "center", gap: "6px", ...F }}>
                  <X size={15} /> Reject
                </button>
                <button onClick={() => { updateStatus(detail.id, "approved"); setDetail(null); }}
                  style={{ flex: 2, height: "42px", borderRadius: "11px", background: "linear-gradient(135deg,#10b981,#059669)", border: "none", color: "white", fontSize: "13px", fontWeight: 700, cursor: "pointer", boxShadow: "0 4px 14px rgba(16,185,129,0.4)", display: "flex", alignItems: "center", justifyContent: "center", gap: "6px", ...F }}>
                  <Check size={15} /> Approve KYC
                </button>
              </div>
            )}
            {detail.status !== "pending" && (
              <div style={{ padding: "16px 20px", borderTop: "1px solid #f1f5f9" }}>
                <div style={{ padding: "12px 16px", borderRadius: "11px", background: STATUS_CONFIG[detail.status as KycStatus].bg, border: `1px solid ${STATUS_CONFIG[detail.status as KycStatus].border}`, display: "flex", alignItems: "center", gap: "10px" }}>
                  {detail.status === "approved" ? <BadgeCheck size={20} color="#059669" /> : <XCircle size={20} color="#ef4444" />}
                  <span style={{ fontSize: "13px", fontWeight: 700, color: STATUS_CONFIG[detail.status as KycStatus].color }}>
                    This application has been {detail.status}
                  </span>
                </div>
              </div>
            )}
          </div>
        </>
      )}
    </div>
  );
};

export default VendorKYCPage;
