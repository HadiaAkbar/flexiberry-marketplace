import { useState } from "react";
import {
  Package, Plus, Search, Filter, Edit2, Trash2,
  Eye, TrendingUp, Star, MoreHorizontal, Upload,
  CheckCircle, XCircle, AlertCircle, ChevronDown,
  Image, Tag, BarChart2,
} from "lucide-react";
import { featuredProducts, formatPrice } from "@/data/products";

const CATEGORY_COLORS: Record<string, string> = {
  phones: "#e53e3e", laptops: "#6D28D9", bikes: "#C05621",
  appliances: "#B91C1C", solar: "#B45309", furniture: "#065F46",
  jahez: "#BE185D", cars: "#0369A1", "raw-materials": "#3F6212", general: "#2563eb",
};

const STATUS_CONFIG = {
  active:   { label: "Active",   bg: "#d1fae5", color: "#065f46", border: "#a7f3d0", icon: CheckCircle },
  inactive: { label: "Inactive", bg: "#fef3c7", color: "#92400e", border: "#fde68a", icon: AlertCircle },
  rejected: { label: "Rejected", bg: "#fee2e2", color: "#991b1b", border: "#fecaca", icon: XCircle },
};

const VendorProductsPage = () => {
  const [search, setSearch] = useState("");
  const [categoryFilter, setCategoryFilter] = useState("all");
  const [statusFilter, setStatusFilter] = useState("all");
  const [sortBy, setSortBy] = useState("newest");
  const [selectedIds, setSelectedIds] = useState<Set<string>>(new Set());
  const [showAddModal, setShowAddModal] = useState(false);
  const [viewMode, setViewMode] = useState<"table" | "grid">("table");

  const F = { fontFamily: "'DM Sans', system-ui, sans-serif" };

  // Enrich products with mock status
  const products = featuredProducts.slice(0, 18).map((p, i) => ({
    ...p,
    status: i % 7 === 0 ? "inactive" : i % 11 === 0 ? "rejected" : "active",
    views: Math.floor(Math.random() * 5000) + 200,
    sold: Math.floor(Math.random() * 300) + 10,
    stock: Math.floor(Math.random() * 50) + 1,
    categoryColor: CATEGORY_COLORS[p.categoryId] || "#2563eb",
  }));

  const filtered = products.filter((p) => {
    const matchSearch = p.name.toLowerCase().includes(search.toLowerCase());
    const matchCat = categoryFilter === "all" || p.categoryId === categoryFilter;
    const matchStatus = statusFilter === "all" || p.status === statusFilter;
    return matchSearch && matchCat && matchStatus;
  });

  const toggleSelect = (id: string) => {
    const next = new Set(selectedIds);
    next.has(id) ? next.delete(id) : next.add(id);
    setSelectedIds(next);
  };

  const selectAll = () => {
    if (selectedIds.size === filtered.length) setSelectedIds(new Set());
    else setSelectedIds(new Set(filtered.map((p) => p.id)));
  };

  const stats = [
    { label: "Total Products", val: products.length, icon: Package, color: "#2563eb", bg: "#eff6ff" },
    { label: "Active Listings", val: products.filter((p) => p.status === "active").length, icon: CheckCircle, color: "#10b981", bg: "#ecfdf5" },
    { label: "Total Views",     val: "47.2K", icon: Eye,       color: "#8b5cf6", bg: "#f5f3ff" },
    { label: "Total Sold",      val: "2,841", icon: TrendingUp, color: "#f59e0b", bg: "#fffbeb" },
  ];

  return (
    <div style={{ ...F, minHeight: "100%" }}>

      {/* ── Header ── */}
      <div style={{ display: "flex", alignItems: "flex-start", justifyContent: "space-between", marginBottom: "24px", flexWrap: "wrap", gap: "12px" }}>
        <div>
          <h1 style={{ fontSize: "22px", fontWeight: 900, color: "#0f172a", margin: "0 0 4px", letterSpacing: "-0.02em" }}>Products</h1>
          <p style={{ fontSize: "13px", color: "#94a3b8", margin: 0 }}>Manage your product listings</p>
        </div>
        <div style={{ display: "flex", gap: "10px" }}>
          <button style={{ height: "40px", paddingInline: "16px", borderRadius: "11px", background: "white", border: "1.5px solid rgba(37,99,235,0.15)", cursor: "pointer", fontSize: "12px", fontWeight: 700, color: "#475569", display: "flex", alignItems: "center", gap: "6px", ...F }}>
            <Upload size={14} /> Import CSV
          </button>
          <button
            onClick={() => setShowAddModal(true)}
            style={{ height: "40px", paddingInline: "18px", borderRadius: "11px", background: "linear-gradient(135deg,#2563eb,#7c3aed)", border: "none", cursor: "pointer", color: "white", fontSize: "12px", fontWeight: 700, display: "flex", alignItems: "center", gap: "6px", boxShadow: "0 4px 14px rgba(37,99,235,0.35)", ...F }}>
            <Plus size={14} /> Add Product
          </button>
        </div>
      </div>

      {/* ── Stats ── */}
      <div style={{ display: "grid", gridTemplateColumns: "repeat(4,1fr)", gap: "14px", marginBottom: "22px" }}>
        {stats.map((s) => (
          <div key={s.label} style={{ background: "white", borderRadius: "16px", border: "1.5px solid rgba(37,99,235,0.07)", padding: "16px 18px", display: "flex", alignItems: "center", gap: "14px", boxShadow: "0 2px 8px rgba(0,0,0,0.04)" }}>
            <div style={{ width: "40px", height: "40px", borderRadius: "11px", background: s.bg, display: "flex", alignItems: "center", justifyContent: "center", flexShrink: 0 }}>
              <s.icon size={18} color={s.color} />
            </div>
            <div>
              <div style={{ fontSize: "20px", fontWeight: 900, color: "#0f172a", lineHeight: 1 }}>{s.val}</div>
              <div style={{ fontSize: "11px", color: "#94a3b8", marginTop: "3px" }}>{s.label}</div>
            </div>
          </div>
        ))}
      </div>

      {/* ── Filters ── */}
      <div style={{ background: "white", borderRadius: "16px", border: "1.5px solid rgba(37,99,235,0.07)", padding: "16px 20px", marginBottom: "16px", display: "flex", alignItems: "center", gap: "12px", flexWrap: "wrap", boxShadow: "0 2px 8px rgba(0,0,0,0.03)" }}>
        {/* Search */}
        <div style={{ position: "relative", flex: 1, minWidth: "200px" }}>
          <Search size={14} color="#94a3b8" style={{ position: "absolute", left: "12px", top: "50%", transform: "translateY(-50%)", pointerEvents: "none" }} />
          <input
            placeholder="Search products…"
            value={search}
            onChange={(e) => setSearch(e.target.value)}
            style={{ width: "100%", height: "38px", paddingLeft: "34px", paddingRight: "12px", borderRadius: "10px", border: "1.5px solid #e2e8f0", fontSize: "13px", outline: "none", boxSizing: "border-box", ...F, color: "#0f172a", background: "#f8fafc" }}
          />
        </div>

        {/* Status filter */}
        <div style={{ position: "relative" }}>
          <select value={statusFilter} onChange={(e) => setStatusFilter(e.target.value)}
            style={{ height: "38px", paddingInline: "12px 32px", borderRadius: "10px", border: "1.5px solid #e2e8f0", fontSize: "12px", fontWeight: 600, color: "#475569", background: "#f8fafc", outline: "none", cursor: "pointer", appearance: "none", ...F }}>
            <option value="all">All Status</option>
            <option value="active">Active</option>
            <option value="inactive">Inactive</option>
            <option value="rejected">Rejected</option>
          </select>
          <ChevronDown size={12} style={{ position: "absolute", right: "10px", top: "50%", transform: "translateY(-50%)", pointerEvents: "none", color: "#94a3b8" }} />
        </div>

        {/* Sort */}
        <div style={{ position: "relative" }}>
          <select value={sortBy} onChange={(e) => setSortBy(e.target.value)}
            style={{ height: "38px", paddingInline: "12px 32px", borderRadius: "10px", border: "1.5px solid #e2e8f0", fontSize: "12px", fontWeight: 600, color: "#475569", background: "#f8fafc", outline: "none", cursor: "pointer", appearance: "none", ...F }}>
            <option value="newest">Newest First</option>
            <option value="price-high">Price: High to Low</option>
            <option value="price-low">Price: Low to High</option>
            <option value="most-viewed">Most Viewed</option>
          </select>
          <ChevronDown size={12} style={{ position: "absolute", right: "10px", top: "50%", transform: "translateY(-50%)", pointerEvents: "none", color: "#94a3b8" }} />
        </div>

        {/* View toggle */}
        <div style={{ display: "flex", background: "#f1f5f9", borderRadius: "10px", padding: "3px", gap: "2px" }}>
          {(["table", "grid"] as const).map((mode) => (
            <button key={mode} onClick={() => setViewMode(mode)}
              style={{ height: "30px", paddingInline: "12px", borderRadius: "8px", border: "none", cursor: "pointer", fontSize: "11px", fontWeight: 700, transition: "all 0.18s", ...F, background: viewMode === mode ? "white" : "transparent", color: viewMode === mode ? "#0f172a" : "#94a3b8", boxShadow: viewMode === mode ? "0 1px 4px rgba(0,0,0,0.1)" : "none" }}>
              {mode === "table" ? "≡ Table" : "⊞ Grid"}
            </button>
          ))}
        </div>

        <span style={{ fontSize: "12px", color: "#94a3b8", marginLeft: "auto", whiteSpace: "nowrap" }}>{filtered.length} products</span>
      </div>

      {/* ── Bulk actions bar ── */}
      {selectedIds.size > 0 && (
        <div style={{ background: "linear-gradient(135deg,#2563eb,#7c3aed)", borderRadius: "12px", padding: "12px 20px", marginBottom: "12px", display: "flex", alignItems: "center", gap: "16px" }}>
          <span style={{ color: "white", fontSize: "13px", fontWeight: 700 }}>{selectedIds.size} selected</span>
          <div style={{ display: "flex", gap: "8px", marginLeft: "auto" }}>
            {["Activate", "Deactivate", "Delete"].map((action) => (
              <button key={action} style={{ height: "32px", paddingInline: "14px", borderRadius: "8px", border: "1px solid rgba(255,255,255,0.3)", background: "rgba(255,255,255,0.15)", color: "white", fontSize: "11px", fontWeight: 700, cursor: "pointer", ...F }}>
                {action}
              </button>
            ))}
          </div>
        </div>
      )}

      {/* ── Table ── */}
      {viewMode === "table" ? (
        <div style={{ background: "white", borderRadius: "18px", border: "1.5px solid rgba(37,99,235,0.07)", overflow: "hidden", boxShadow: "0 4px 20px rgba(0,0,0,0.04)" }}>
          {/* Table header */}
          <div style={{ display: "grid", gridTemplateColumns: "40px 1fr 110px 110px 100px 90px 90px 90px", padding: "12px 20px", background: "#fafbff", borderBottom: "1px solid #f1f5f9", gap: "12px", alignItems: "center" }}>
            <input type="checkbox" checked={selectedIds.size === filtered.length && filtered.length > 0} onChange={selectAll}
              style={{ width: "16px", height: "16px", cursor: "pointer", accentColor: "#2563eb" }} />
            {["Product", "Price", "Category", "Status", "Views", "Sold", "Actions"].map((h) => (
              <span key={h} style={{ fontSize: "10px", fontWeight: 800, color: "#94a3b8", letterSpacing: "0.06em", textTransform: "uppercase" }}>{h}</span>
            ))}
          </div>

          {/* Rows */}
          {filtered.map((p, i) => {
            const sc = STATUS_CONFIG[p.status as keyof typeof STATUS_CONFIG];
            const disc = p.originalPrice ? Math.round(((p.originalPrice - p.price) / p.originalPrice) * 100) : 0;
            return (
              <div key={p.id}
                style={{ display: "grid", gridTemplateColumns: "40px 1fr 110px 110px 100px 90px 90px 90px", padding: "14px 20px", borderBottom: "1px solid #f8fafc", gap: "12px", alignItems: "center", transition: "background 0.15s", background: selectedIds.has(p.id) ? "#f0f6ff" : "transparent" }}
                onMouseEnter={e => { if (!selectedIds.has(p.id)) e.currentTarget.style.background = "#fafbff"; }}
                onMouseLeave={e => { if (!selectedIds.has(p.id)) e.currentTarget.style.background = "transparent"; }}
              >
                <input type="checkbox" checked={selectedIds.has(p.id)} onChange={() => toggleSelect(p.id)}
                  style={{ width: "16px", height: "16px", cursor: "pointer", accentColor: "#2563eb" }} />

                {/* Product */}
                <div style={{ display: "flex", alignItems: "center", gap: "12px", minWidth: 0 }}>
                  <div style={{ width: "44px", height: "44px", borderRadius: "10px", overflow: "hidden", background: "#f1f5f9", flexShrink: 0 }}>
                    <img src={p.image} alt={p.name} style={{ width: "100%", height: "100%", objectFit: "cover" }} />
                  </div>
                  <div style={{ minWidth: 0 }}>
                    <p style={{ fontSize: "13px", fontWeight: 700, color: "#0f172a", margin: "0 0 2px", whiteSpace: "nowrap", overflow: "hidden", textOverflow: "ellipsis" }}>{p.name}</p>
                    <p style={{ fontSize: "11px", color: "#94a3b8", margin: 0 }}>SKU: {p.id.toUpperCase()}-001 · Stock: {p.stock}</p>
                  </div>
                </div>

                {/* Price */}
                <div>
                  <p style={{ fontSize: "13px", fontWeight: 800, color: "#0f172a", margin: 0 }}>{formatPrice(p.price)}</p>
                  {disc > 0 && <p style={{ fontSize: "10px", color: "#ef4444", margin: 0, fontWeight: 700 }}>-{disc}% OFF</p>}
                </div>

                {/* Category */}
                <div>
                  <span style={{ fontSize: "10px", fontWeight: 700, padding: "3px 8px", borderRadius: "6px", background: p.categoryColor + "18", color: p.categoryColor, textTransform: "capitalize" }}>
                    {p.categoryId}
                  </span>
                </div>

                {/* Status */}
                <div>
                  <span style={{ display: "inline-flex", alignItems: "center", gap: "4px", fontSize: "10px", fontWeight: 700, padding: "4px 9px", borderRadius: "20px", background: sc.bg, color: sc.color, border: `1px solid ${sc.border}` }}>
                    <sc.icon size={9} /> {sc.label}
                  </span>
                </div>

                {/* Views */}
                <div style={{ display: "flex", alignItems: "center", gap: "4px" }}>
                  <Eye size={12} color="#94a3b8" />
                  <span style={{ fontSize: "12px", fontWeight: 600, color: "#475569" }}>{p.views.toLocaleString()}</span>
                </div>

                {/* Sold */}
                <div style={{ display: "flex", alignItems: "center", gap: "4px" }}>
                  <TrendingUp size={12} color="#10b981" />
                  <span style={{ fontSize: "12px", fontWeight: 600, color: "#475569" }}>{p.sold}</span>
                </div>

                {/* Actions */}
                <div style={{ display: "flex", alignItems: "center", gap: "4px" }}>
                  {[{ icon: Eye, color: "#2563eb", bg: "#eff6ff" }, { icon: Edit2, color: "#8b5cf6", bg: "#f5f3ff" }, { icon: Trash2, color: "#ef4444", bg: "#fee2e2" }].map(({ icon: Icon, color, bg }, j) => (
                    <button key={j} style={{ width: "28px", height: "28px", borderRadius: "7px", background: bg, border: "none", cursor: "pointer", display: "flex", alignItems: "center", justifyContent: "center", transition: "opacity 0.15s" }}
                      onMouseEnter={e => (e.currentTarget.style.opacity = "0.75")}
                      onMouseLeave={e => (e.currentTarget.style.opacity = "1")}>
                      <Icon size={12} color={color} />
                    </button>
                  ))}
                </div>
              </div>
            );
          })}

          {/* Footer */}
          <div style={{ padding: "14px 20px", background: "#fafbff", borderTop: "1px solid #f1f5f9", display: "flex", alignItems: "center", justifyContent: "space-between" }}>
            <span style={{ fontSize: "12px", color: "#94a3b8" }}>Showing {filtered.length} of {products.length} products</span>
            <div style={{ display: "flex", gap: "6px" }}>
              {[1, 2, 3, "…", 8].map((page, i) => (
                <button key={i} style={{ width: "32px", height: "32px", borderRadius: "8px", border: "1.5px solid", fontSize: "12px", fontWeight: 700, cursor: "pointer", ...F, borderColor: page === 1 ? "#2563eb" : "#e2e8f0", background: page === 1 ? "#2563eb" : "white", color: page === 1 ? "white" : "#475569" }}>
                  {page}
                </button>
              ))}
            </div>
          </div>
        </div>
      ) : (
        /* ── Grid view ── */
        <div style={{ display: "grid", gridTemplateColumns: "repeat(auto-fill,minmax(220px,1fr))", gap: "16px" }}>
          {filtered.map((p) => {
            const sc = STATUS_CONFIG[p.status as keyof typeof STATUS_CONFIG];
            return (
              <div key={p.id} style={{ background: "white", borderRadius: "18px", border: "1.5px solid rgba(37,99,235,0.07)", overflow: "hidden", boxShadow: "0 2px 10px rgba(0,0,0,0.05)", transition: "transform 0.2s, box-shadow 0.2s" }}
                onMouseEnter={e => { (e.currentTarget as HTMLElement).style.transform = "translateY(-3px)"; (e.currentTarget as HTMLElement).style.boxShadow = "0 10px 30px rgba(0,0,0,0.1)"; }}
                onMouseLeave={e => { (e.currentTarget as HTMLElement).style.transform = "none"; (e.currentTarget as HTMLElement).style.boxShadow = "0 2px 10px rgba(0,0,0,0.05)"; }}>
                <div style={{ position: "relative", aspectRatio: "1", background: "#f8fafc", overflow: "hidden" }}>
                  <img src={p.image} alt={p.name} style={{ width: "100%", height: "100%", objectFit: "cover" }} />
                  <span style={{ position: "absolute", top: "10px", left: "10px", fontSize: "10px", fontWeight: 700, padding: "3px 8px", borderRadius: "6px", background: sc.bg, color: sc.color, border: `1px solid ${sc.border}` }}>{sc.label}</span>
                </div>
                <div style={{ padding: "14px" }}>
                  <p style={{ fontSize: "13px", fontWeight: 700, color: "#0f172a", margin: "0 0 4px", lineHeight: 1.3 }}>{p.name}</p>
                  <p style={{ fontSize: "14px", fontWeight: 900, color: p.categoryColor, margin: "0 0 10px" }}>{formatPrice(p.price)}</p>
                  <div style={{ display: "flex", gap: "6px" }}>
                    <button style={{ flex: 1, height: "32px", borderRadius: "8px", background: "#eff6ff", border: "none", cursor: "pointer", fontSize: "11px", fontWeight: 700, color: "#2563eb", ...F }}>Edit</button>
                    <button style={{ width: "32px", height: "32px", borderRadius: "8px", background: "#fee2e2", border: "none", cursor: "pointer", display: "flex", alignItems: "center", justifyContent: "center" }}>
                      <Trash2 size={13} color="#ef4444" />
                    </button>
                  </div>
                </div>
              </div>
            );
          })}
        </div>
      )}

      {/* ── Add Product Modal ── */}
      {showAddModal && (
        <>
          <div onClick={() => setShowAddModal(false)} style={{ position: "fixed", inset: 0, background: "rgba(0,0,0,0.4)", backdropFilter: "blur(4px)", zIndex: 998 }} />
          <div style={{ position: "fixed", top: "50%", left: "50%", transform: "translate(-50%,-50%)", zIndex: 999, width: "min(560px,94vw)", background: "white", borderRadius: "24px", boxShadow: "0 40px 100px rgba(0,0,0,0.2)", overflow: "hidden", ...F }}>
            <div style={{ background: "linear-gradient(135deg,#2563eb,#7c3aed)", padding: "22px 24px", display: "flex", alignItems: "center", justifyContent: "space-between" }}>
              <div style={{ display: "flex", alignItems: "center", gap: "10px" }}>
                <div style={{ width: "36px", height: "36px", borderRadius: "10px", background: "rgba(255,255,255,0.2)", display: "flex", alignItems: "center", justifyContent: "center" }}>
                  <Package size={18} color="white" />
                </div>
                <div>
                  <h2 style={{ color: "white", fontWeight: 800, fontSize: "16px", margin: 0 }}>Add New Product</h2>
                  <p style={{ color: "rgba(255,255,255,0.7)", fontSize: "11px", margin: 0 }}>Fill in product details below</p>
                </div>
              </div>
              <button onClick={() => setShowAddModal(false)} style={{ width: "30px", height: "30px", borderRadius: "50%", background: "rgba(255,255,255,0.2)", border: "none", color: "white", cursor: "pointer", fontSize: "18px", display: "flex", alignItems: "center", justifyContent: "center" }}>×</button>
            </div>
            <div style={{ padding: "24px", display: "flex", flexDirection: "column", gap: "14px" }}>
              {/* Image upload */}
              <div style={{ border: "2px dashed #e2e8f0", borderRadius: "14px", padding: "24px", textAlign: "center", cursor: "pointer", background: "#f8fafc" }}
                onMouseEnter={e => (e.currentTarget.style.borderColor = "#2563eb")}
                onMouseLeave={e => (e.currentTarget.style.borderColor = "#e2e8f0")}>
                <Image size={28} color="#94a3b8" style={{ margin: "0 auto 8px" }} />
                <p style={{ fontSize: "13px", fontWeight: 600, color: "#475569", margin: "0 0 4px" }}>Click to upload product images</p>
                <p style={{ fontSize: "11px", color: "#94a3b8", margin: 0 }}>PNG, JPG up to 10MB each</p>
              </div>

              <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: "12px" }}>
                {[
                  { label: "Product Name", placeholder: "e.g. Samsung Galaxy S25" },
                  { label: "Brand", placeholder: "e.g. Samsung" },
                ].map(({ label, placeholder }) => (
                  <div key={label}>
                    <label style={{ fontSize: "11px", fontWeight: 700, color: "#374151", display: "block", marginBottom: "5px" }}>{label}</label>
                    <input placeholder={placeholder} style={{ width: "100%", height: "40px", paddingInline: "12px", borderRadius: "10px", border: "1.5px solid #e2e8f0", fontSize: "13px", outline: "none", boxSizing: "border-box", ...F }} />
                  </div>
                ))}
              </div>

              <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: "12px" }}>
                {[
                  { label: "Price (PKR)", placeholder: "e.g. 89999" },
                  { label: "Original Price", placeholder: "e.g. 99999" },
                ].map(({ label, placeholder }) => (
                  <div key={label}>
                    <label style={{ fontSize: "11px", fontWeight: 700, color: "#374151", display: "block", marginBottom: "5px" }}>{label}</label>
                    <input placeholder={placeholder} type="number" style={{ width: "100%", height: "40px", paddingInline: "12px", borderRadius: "10px", border: "1.5px solid #e2e8f0", fontSize: "13px", outline: "none", boxSizing: "border-box", ...F }} />
                  </div>
                ))}
              </div>

              <div>
                <label style={{ fontSize: "11px", fontWeight: 700, color: "#374151", display: "block", marginBottom: "5px" }}>Description</label>
                <textarea rows={3} placeholder="Product description…" style={{ width: "100%", padding: "10px 12px", borderRadius: "10px", border: "1.5px solid #e2e8f0", fontSize: "13px", outline: "none", resize: "none", boxSizing: "border-box", ...F }} />
              </div>

              <div style={{ display: "flex", gap: "10px", marginTop: "4px" }}>
                <button onClick={() => setShowAddModal(false)} style={{ flex: 1, height: "44px", borderRadius: "12px", border: "1.5px solid #e2e8f0", background: "white", fontSize: "13px", fontWeight: 700, color: "#475569", cursor: "pointer", ...F }}>Cancel</button>
                <button style={{ flex: 2, height: "44px", borderRadius: "12px", background: "linear-gradient(135deg,#2563eb,#7c3aed)", border: "none", color: "white", fontSize: "13px", fontWeight: 700, cursor: "pointer", boxShadow: "0 6px 18px rgba(37,99,235,0.35)", ...F }}>
                  Publish Product
                </button>
              </div>
            </div>
          </div>
        </>
      )}
    </div>
  );
};

export default VendorProductsPage;
